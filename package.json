{
  "name": "@chess/monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Chinese Chess (Xiangqi) pnpm workspace monorepo",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:backend": "pnpm --filter @chess/backend dev",
    "dev:frontend": "pnpm --filter @chess/frontend dev",
    "build": "pnpm run build:logger && pnpm run build:backend && pnpm run build:frontend",
    "build:logger": "pnpm --filter @chess/logger build",
    "build:backend": "pnpm --filter @chess/backend build",
    "build:frontend": "pnpm --filter @chess/frontend build",
    "start": "pnpm --filter @chess/backend start",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
