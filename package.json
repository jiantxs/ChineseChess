{
  "name": "chinese-chess",
  "version": "1.0.0",
  "description": "Chinese Chess (Xiangqi) web application with online multiplayer",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "ts-node-dev --respawn --transpile-only backend/src/index.ts",
    "dev:frontend": "cd frontend && vite",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && vite build",
    "build:backend": "tsc -p backend/tsconfig.json",
    "start": "node backend/dist/backend/src/index.js",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
