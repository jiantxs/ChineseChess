{
  "name": "@chess/monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Chinese Chess (Xiangqi) pnpm workspace monorepo",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:backend": "pnpm --filter @chess/backend dev",
    "dev:frontend": "pnpm --filter @chess/frontend dev",
    "build": "pnpm run build:logger && pnpm run build:game-records && pnpm run build:backend && pnpm run build:frontend && pnpm run build:core && pnpm run build:config",
    "build:logger": "pnpm --filter @chess/logger build",
    "build:game-records": "pnpm --filter @chess/game-records build",
    "build:backend": "pnpm --filter @chess/backend build",
    "build:frontend": "pnpm --filter @chess/frontend build",
    "build:config": "pnpm --filter @chess/config build",
    "build:core": "pnpm --filter @chess/core build",
    "build:electron": "pnpm --filter @chess/electron dist",
    "start": "pnpm --filter @chess/backend start",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron"]
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "concurrently": "^8.2.2"
  }
}
