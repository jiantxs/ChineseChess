{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "../..",
    "paths": {
      "@chess/core": ["packages/core/src"],
      "@chess/core/*": ["packages/core/src/*"],
      "@chess/config": ["packages/config/src"],
      "@chess/config/*": ["packages/config/src/*"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../core" },
    { "path": "../config" }
  ]
}
