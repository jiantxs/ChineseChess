{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "lib": ["ES2022"],
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@chess/preference": ["../preference/src"],
      "@chess/preference/*": ["../preference/src/*"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../core" },
    { "path": "../config" },
    { "path": "../game-records" },
    { "path": "../logger" },
    { "path": "../preference" }
  ]
}
