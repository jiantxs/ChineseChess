{
  "name": "@chess/electron",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc --build",
    "build:backend": "node scripts/build-backend.js",
    "dist": "pnpm run build && pnpm run build:backend && electron-builder",
    "dist:dir": "pnpm run build:backend && electron-builder --dir",
    "dev": "pnpm run build:backend && tsc --build && electron .",
    "clean": "rm -rf dist backend-dist"
  },
  "dependencies": {
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "electron-builder": "^24.13.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "electron": "^30.0.0"
  },
  "build": {
    "appId": "com.chess.desktop",
    "productName": "象棋",
    "directories": {
      "output": "../../winapp"
    },
    "files": [
      "dist/**/*",
      "backend-dist/**/*"
    ],
    "extraResources": [
      {
        "from": "backend-dist",
        "to": "backend-dist"
      },
      {
        "from": "node-dist",
        "to": "node-dist"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
