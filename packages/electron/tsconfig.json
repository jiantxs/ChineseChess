{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "types": ["node"],
    "paths": {
      "@chess/backend": ["../backend/src"],
      "@chess/backend/*": ["../backend/src/*"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../backend" }
  ]
}
